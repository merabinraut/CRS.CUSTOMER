    <style>
        .ui-datepicker {
            /* width: max-content; */
            width: 98%;
            background-color: #FBF8F8;
            padding: 12px 8px;
            position: relative !important;
            top: unset !important;
            left: unset !important;
            border: none !important;
            font-family: "Noto Sans", sans-serif;
            font-size: 14px;
            display: block !important;
            border-radius: 8px;
        }


        .ui-state-default {
            display: flex !important;
            align-items: center;
            justify-content: center;
            border: none !important;
            background: inherit !important;
            font-weight: normal;
            color: #454545;
            height: 36px;
            width: 36px;
            position: relative;
            left: 50%;
            transform: translateX(-50%);
            border: 1px solid #FBF8F8 !important;
        }

        .ui-state-active,
        .ui-widget-content .ui-state-active,
        .ui-widget-header .ui-state-active,
        a.ui-button:active,
        .ui-button:active,
        .ui-button.ui-state-active:hover {
            border: 1px solid #D75A8B !important;
            background: inherit !important;
            font-weight: normal;
            color: #D75A8B !important;
            text-align: center;
            border-radius: 5px;
        }

        .ui-state-highlight,
        .ui-widget-content .ui-state-highlight,
        .ui-widget-header .ui-state-highlight {
            border: 1px solid #D75A8B !important;
            background: #D75A8B !important;
            color: #FFFFFF !important;
            border-radius: 5px;
        }

        .ui-widget-header {
            border: none;
            background-color: inherit !important;
        }

        .ui-datepicker .ui-datepicker-title {
            text-align: left;
            margin: 0px;
            color: #44464F;
            font-family: "Noto Sans JP";
            font-size: 14px;
            font-style: normal;
            font-weight: 500;
            line-height: 20px;
            /* 142.857% */
            letter-spacing: 0.1px;
            padding: 10px 8px;
        }

        .ui-datepicker .ui-datepicker-prev {
            right: 45px;
            left: unset !important;
            height: 40px;
            width: 40px;
            border: 1px solid #FBF8F8;
            cursor: pointer;
        }

        .ui-datepicker .ui-datepicker-next {
            height: 40px;
            width: 40px;
            right: 10px !important;
            border: 1px solid #FBF8F8;
            cursor: pointer;
        }

            .ui-datepicker .ui-datepicker-next span {
                background-image: url("../../Content/assets/images/navigate_next.svg");
                background-repeat: no-repeat;
                background-position: center;
            }

        .ui-datepicker .ui-datepicker-prev span {
            background-image: url("../../Content/assets/images/navigate_before.svg");
            background-repeat: no-repeat;
            background-position: center;
        }

        .ui-datepicker th:last-child {
            color: #D75A8B;
        }

        .ui-datepicker th:nth-last-child(2) {
            color: #697DBF;
        }

        #selectedDateBtn {
            margin-top: 10px;
            padding: 8px 16px;
            background-color: #D75A8B;
            color: #fff;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        .disable-click {
            pointer-events: none;
        }

        .affiliation {
            display: flex;
            padding: 4px 0px;
            justify-content: center;
            align-items: center;
            gap: 8px;
            margin-top: 8px;
            display: none;
        }

        .affiliationText {
            color: #999;
            text-align: center;
            font-family: "Noto Sans JP";
            font-size: 11px;
            font-style: normal;
            font-weight: 700;
            line-height: 166%;
        }

        .dividerCol {
            color: #999;
            text-align: center;
            font-family: "Noto Sans JP";
            font-size: 11px;
            font-style: normal;
            font-weight: 700;
            line-height: 166%;
            display: none
            /* 18.26px */
        }
    </style>
